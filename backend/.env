# MedQueue GH Backend Environment Variables
# Copy this to .env and replace placeholder values with actual credentials

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Qwerty@123
DB_NAME=medqueue_gh

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRES_IN=24h

# OpenAI API (for chatbot)
OPENAI_API_KEY=your_openai_api_key_here

# Twilio WhatsApp API (for messaging)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number_here

# Server Configuration
PORT=3000